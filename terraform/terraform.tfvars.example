# Copy to terraform.tfvars and fill in real values.
# terraform.tfvars is in .gitignore — never commit it.

region              = "sa-saopaulo-1"
compartment_id      = "ocid1.compartment.oc1..aaaa<REPLACE>"
availability_domain = "<REPLACE>:SA-SAOPAULO-1-AD-1"
ssh_public_key      = "ssh-rsa AAAA... user@host"

